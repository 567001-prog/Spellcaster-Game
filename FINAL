def monster_attacks():
   #wait 2 seconds
   time.sleep(2)

   global player_health
   monster_damage = rand.randint(7,17)

   writer.clear()
   writer.goto(0, 100)
   writer.write('Incoming attack!', align = 'center', font = ('Book Antiqua', 24, 'normal'))

   projectile.shape("monster_attack.gif")
   projectile.goto(monster_x, monster_y)
   projectile.showturtle()
   projectile.penup()
   projectile.speed(1.5)
   projectile.goto(player_x, player_y)
   projectile.hideturtle()

   player_health -= monster_damage
   print(f"Hit! Your health is now {player_health}")

   writer.clear()

   time.sleep(1)

def countdown():
  global timer, timer_up
  while timer > 0 and not timer_up:
    print("\rTimer: " + str(timer) + "  ", end='', flush = True)
    timer -= 1
    time.sleep(1)
  if not timer_up:
    print("\rTime's Up!   Press OK to continue   ")
    timer_up = True

# check if the user's answer is correct 
# + what happens when the user types correct or incorrect answer
def check_answer():
  global timer_up, attempt, full_attack
  if timer_up:
    return
  if (attempt == full_attack):
    writer.clear()
    writer.penup()
    writer.goto(0, 100)
    writer.write('Attack!', align = 'center', font=('Book Antiqua', 24, 'normal'))
    timer_up = True
    print("Correct!")
    launch_attack(full_attack)
  while not timer_up and attempt != full_attack:
    attempt = wn.textinput("Wrong!", "Try again:")
    check_answer()

# shuffles answer and waits for the user to type in the incorrect or correct answer
def attack_answer():
    global attempt, timer, timer_up, lvl, wonq, monster_health

    timer = 10
    timer_up = False

    #scramble element and attack
    ele = list(element)
    rand.shuffle(ele)
    shuf_ele = ''.join(ele)

    ata = list(attack)
    rand.shuffle(ata)
    shuf_ata = ''.join(ata)

    shuf_full = shuf_ele + ' ' + shuf_ata

    writer.clear()
    writer.penup()
    writer.hideturtle()
    writer.goto(0, 100)
    writer.write(shuf_full, align = 'center', font = ('Book Antiqua', 24, 'normal'))

    threading.Thread(target = countdown, daemon = True).start()

    attempt = wn.textinput("Spell Check", "Type the spell:")

    if not timer_up:
        check_answer()
    
    if monster_health > 0:
      if player_health <= 0:
        writer.clear()
        writer.goto(0, 100)
        writer.write('You lose', align='center', font = ('Book Antiqua', 36, 'bold'))
        wonq = False
        time.sleep(3)
        writer.clear()
      else:
        monster_attacks()
    
    elif monster_health <= 0:
      writer.clear()
      writer.goto(0, 100)
      writer.write('You won!', align = 'center', font = ('Book Antiqua', 24, 'normal'))

      wonq = True

      time.sleep(3)
      writer.clear()
      monster.hideturtle()
      mc.hideturtle()

def end():
    global name, wonq
    bank.clear()

    pen.clear()
    if wonq:
        status = "VICTORY"
        message_color = "gold"
        end_text = [
            f"Congratulations, {name}!",
            "Thank you so much for saving our kingdom!"
        ]
    else:
        status = "DEFEAT"
        message_color = "red"
        end_text = [
            f"You lost, {name}...",
            f"The kingdom has collapsed..."
        ]

    pen.color(message_color)
    pen.goto(0, 180)
    pen.write(status, align="center", font=("Impact", 40, "bold"))

    pen.color("white")
    current_y = 80

    for line in end_text:
        pen.goto(0, current_y)
        pen.write(
            line,
            align="center",
            font=("Times New Roman", 22, "bold")
        )
        current_y -= 50

