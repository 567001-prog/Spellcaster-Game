def start():
    global name

    name = wn.textinput("Name Entry", "What is your name?")

    if name is None:
        name = "loser"

    intro_text = [
        f"Hello, {name}! Your kingdom is under attack.",
        "You must defeat the monsters to save the kingdom.",
        "Unscramble the spell before time runs out.",
        "There are 4 monsters headed your way.",
        "Good luck!"
    ]
    

    current_y = 120

    for line in intro_text:
        pen.goto(0, current_y)

        pen.write(
            line,
            align="center",
            font=("Times New Roman", 25, "bold")
        )

        current_y -= 50
    
def random_attack():
    global element, attack, damage, full_attack
    # pick random element
    rand_index = rand.randint(0, len(elements) - 1)
    element = elements[rand_index]
    base_damage = element_damages[rand_index]

    # pick random attack type
    rand_index2 = rand.randint(0, len(attack_types) - 1)
    attack = attack_types[rand_index2]
    multiplier = attack_multipliers[rand_index2]

    # calculate damage
    damage = base_damage * multiplier
    damage = int(damage)  # remove decimal

    full_attack = element + ' ' + attack

