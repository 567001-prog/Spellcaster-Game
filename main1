def countdown():
  global timer, timer_up
  while timer > 0 and not timer_up:
    print("\rTimer: " + str(timer) + "  ", end='', flush = True)
    timer -= 1
    time.sleep(1)
  if not timer_up:
    print("\rTime's Up!      ", flush = True)
    timer_up = True

# check if the user's answer is correct 
# + what happens when the user types correct or incorrect answer
def check_answer():
  global timer_up, attempt, full_attack
  if (attempt == full_attack):
    writer.clear()
    writer.penup()
    writer.forward(-50)
    writer.write('Attack!', font=('Book Antiqua', 24, 'normal'))
    timer_up = True
    print("Correct!")
    launch_attack(full_attack) # REPLACE WITH THE ATTACK FUNCTION
  else:
    attempt = input('Try again: ')
    check_answer()

# shuffles answer and waits for the user to type in the incorrect or correct answer
def attack_answer():
    global attempt, timer, timer_up, lvl

    timer = 30
    timer_up = False

    #scramble element and attack
    ele = list(element)
    rand.shuffle(ele)
    shuf_ele = ''.join(ele)

    ata = list(attack)
    rand.shuffle(ata)
    shuf_ata = ''.join(ata)

    shuf_full = shuf_ele + ' ' + shuf_ata

    writer.clear()
    writer.penup()
    writer.hideturtle()
    writer.goto(0, 100)
    writer.write(shuf_full, align = 'center', font = ('Book Antiqua', 24, 'normal'))

    threading.Thread(target = countdown, daemon = True).start()

    attempt = input('')

    if not timer_up:
        check_answer()
    else:
      monster_attacks()
    
    if monster_health > 0:
      monster_attacks()
      #attack_quiz()
    elif player_health <= 0:
      writer.clear()
      writer.write('You lose', font = ('Book Antiqua', 24, 'normal'))

      wonq = False
      # goto end screen
      
    elif monster_health <= 0:
      writer.clear()
      writer.write('You won!', font = ('Book Antiqua', 24, 'normal'))

      wonq = True

      time.sleep(4)
      monster.hideturtle()
      mc.hideturtle()

      if lvl == 2:
        #goto lvl 2
        show_level_screen(lvl)
      elif lvl == 3:
        #goto lvl 3
        show_level_screen(lvl)
      elif lvl == 4:
        #goto lvl 4
        show_level_screen(lvl)
      elif lvl == 'end':
        #goto end screen
        print("end")




